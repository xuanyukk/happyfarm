{
  "name": "backend",
  "version": "4.71.6",
  "main": "index.js",
  "scripts": {
    "test": "jest --config jest.config.js",
    "test:watch": "jest --watch --config jest.config.js",
    "test:coverage": "jest --coverage --config jest.config.js",
    "dev": "node src/server.js",
    "start": "pm2 start ecosystem.config.js",
    "start:prod": "pm2 start ecosystem.config.js --env production",
    "stop": "pm2 stop ecosystem.config.js",
    "restart": "pm2 restart ecosystem.config.js",
    "delete": "pm2 delete ecosystem.config.js",
    "logs": "pm2 logs happy-farm-backend",
    "monit": "pm2 monit",
    "status": "pm2 status",
    "prepare": "husky",
    "lint": "eslint src --ext .js",
    "lint:fix": "eslint src --ext .js --fix",
    "format": "prettier --write \"src/**/*.js\"",
    "schema:validate": "node scripts/schema-validator.js --check",
    "schema:validate:fix": "node scripts/schema-validator.js --fix",
    "schema:validate:report": "node scripts/schema-validator.js --check --output ../sql_init/schema_diff_report.json",
    "er:generate": "node scripts/generate-er-diagram.js --format both",
    "er:generate:mermaid": "node scripts/generate-er-diagram.js --format mermaid",
    "er:generate:html": "node scripts/generate-er-diagram.js --format html"
  },
  "lint-staged": {
    "src/**/*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "axios": "^1.16.1",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.13.0",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "csurf": "^1.11.0",
    "csv-parser": "^3.2.1",
    "csv-stringify": "^6.7.0",
    "dotenv": "^17.3.1",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "express-validator": "^7.3.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "node-schedule": "^2.1.1",
    "nodemailer": "^8.0.3",
    "pg": "^8.20.0",
    "pm2": "^7.0.1",
    "prom-client": "^15.1.3",
    "rate-limit": "^0.1.1",
    "rate-limiter-flexible": "^11.1.0",
    "socket.io": "^4.8.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.2.5",
    "supertest": "^7.0.0"
  }
}
