# ================================================================================
# 开心农场后端环境变量配置模板
# 作者：开发者
# 日期：2026-05-14
# 版本：v1.1.0
# 功能描述：后端服务运行所需的所有环境变量配置模板
# 
# ⚠️ 重要提示：
# 1. 此文件是模板文件，请复制为 .env 并填入实际配置值
# 2. .env 文件包含敏感信息（密码、密钥等），绝对不要提交到版本控制系统
# 3. 生产环境必须修改所有默认密码和密钥
# 4. 修改配置后需要重启服务才能生效
# ================================================================================

# ================================================================================
# 🔌 数据库连接配置
# ================================================================================
# PostgreSQL数据库连接字符串
# 格式：postgresql://用户名:密码@主机:端口/数据库名
# 说明：
#   - 用户名：请根据实际情况修改（默认是postgres）
#   - 密码：数据库密码（必须修改为实际密码）
#   - localhost：数据库主机地址（本地数据库）
#   - 5432：PostgreSQL默认端口
#   - happy_farm：数据库名称
# 
# 配置示例：
#   本地开发：DATABASE_URL="postgresql://postgres:mypassword@localhost:5432/happy_farm"
#   远程数据库：DATABASE_URL="postgresql://user:pass@db.example.com:5432/happy_farm"
DATABASE_URL="postgresql://用户名:密码@localhost:5432/happy_farm"

# 数据库连接单独配置（用于数据库管理脚本）
# 这些变量会被 db_manager.js 使用
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_NAME=happy_farm

# ================================================================================
# 🔐 JWT认证配置
# ================================================================================
# JWT密钥 - 用于签名和验证JWT令牌
# ⚠️ 生产环境必须使用强随机密钥！
# 生成方式：在终端运行以下命令生成随机密钥
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# 说明：此密钥用于保护用户登录状态，泄露会导致安全问题
JWT_SECRET="your_strong_jwt_secret_key_here"

# JWT访问令牌过期时间
# 说明：用户登录后获得的访问令牌有效期
# 格式：支持多种格式，如：
#   - "2h" = 2小时
#   - "30m" = 30分钟
#   - "1d" = 1天
#   - "7d" = 7天
# 建议：生产环境建议设置较短时间（如15-30分钟）提高安全性
JWT_EXPIRES_IN="2h"

# JWT刷新令牌过期时间
# 说明：用于刷新访问令牌的刷新令牌有效期
# 建议：设置较长时间，让用户无需频繁登录
JWT_REFRESH_EXPIRES_IN="30d"

# ================================================================================
# 🖥️ 服务器配置
# ================================================================================
# 服务监听端口
# 说明：后端HTTP服务监听的端口号
# 注意：如果端口被占用，需要修改此值或关闭占用端口的程序
PORT=3001

# 服务监听主机
# 说明：
#   - "localhost"：仅本地可访问（开发环境推荐）
#   - "0.0.0.0"：允许所有IP访问（生产环境需要）
HOST="localhost"

# Node.js运行环境
# 说明：
#   - "development"：开发环境，启用调试日志、热重载等
#   - "production"：生产环境，启用性能优化、禁用调试
NODE_ENV="development"

# ================================================================================
# 📝 日志配置
# ================================================================================
# 日志输出级别
# 说明：控制日志输出的详细程度，从低到高依次为：
#   - "error"：仅输出错误
#   - "warn"：输出警告和错误
#   - "info"：输出一般信息、警告和错误
#   - "debug"：输出所有信息（开发调试用）
LOG_LEVEL="debug"

# 日志文件路径（用于数据库管理脚本）
LOG_FILE=db_operations.log

# ================================================================================
# 🛡️ 安全配置
# ================================================================================
# CORS允许的源地址
# 说明：允许哪些前端域名访问后端API（跨域资源共享）
# 格式：多个地址用逗号分隔
# 示例：
#   本地开发："http://localhost:5173,http://localhost:5174"
#   生产环境："https://farm.example.com,https://admin.farm.example.com"
CORS_ORIGIN="http://localhost:5173,http://localhost:5174"

# 是否启用安全确认 (true/false)
# 说明：设置为 false 可跳过确认提示（生产环境不建议）
SAFETY_CONFIRM=true

# 速率限制时间窗口
# 说明：在多长时间内统计请求次数，防止恶意攻击
# 格式：
#   - "15m" = 15分钟
#   - "1h" = 1小时
#   - "1d" = 1天
RATE_LIMIT_WINDOW="15m"

# 速率限制最大请求数
# 说明：在时间窗口内允许的最大请求数，超过会被拒绝
# 建议：
#   - 开发环境：100-1000（方便测试）
#   - 生产环境：10-100（防止恶意攻击）
RATE_LIMIT_MAX="10"

# ================================================================================
# 📧 邮件服务配置
# ================================================================================
# SMTP服务器地址
# 说明：用于发送邮件的SMTP服务器地址
# 常见服务商：
#   - Gmail：smtp.gmail.com
#   - QQ邮箱：smtp.qq.com
#   - 163邮箱：smtp.163.com
#   - 企业邮箱：请咨询服务商
SMTP_HOST="smtp.example.com"

# SMTP服务器端口
# 说明：
#   - 587：TLS加密端口（推荐）
#   - 465：SSL加密端口
#   - 25：非加密端口（不推荐）
SMTP_PORT="587"

# SMTP用户名
# 说明：登录SMTP服务器的用户名（通常是邮箱地址）
SMTP_USER="your-email@example.com"

# SMTP密码
# 说明：登录SMTP服务器的密码或授权码
# 注意：部分邮箱服务商需要使用授权码而非登录密码
SMTP_PASS="your-email-password"

# 发件人邮箱地址
# 说明：显示在邮件发件人位置的邮箱地址
SMTP_FROM="no-reply@example.com"

# 是否启用邮件服务
# 说明：
#   - "true"：启用邮件发送功能
#   - "false"：禁用邮件功能（密码重置等功能不可用）
SMTP_ENABLED="false"

# 密码重置令牌有效期（分钟）
# 说明：用户请求密码重置后，链接的有效时间
PASSWORD_RESET_TOKEN_EXPIRES="30"

# ================================================================================
# 🔑 数据加密配置
# ================================================================================
# 敏感数据加密密钥
# ⚠️ 生产环境必须使用强随机密钥！
# 生成方式：在终端运行以下命令生成随机密钥
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# 说明：用于加密数据库中存储的敏感数据
ENCRYPTION_KEY="your_strong_encryption_key_here"

# ================================================================================
# 🚀 Redis缓存配置
# ================================================================================
# 是否启用Redis
# 说明：
#   - "true"：启用Redis缓存和队列功能
#   - "false"：禁用Redis，使用内存缓存（不推荐生产环境）
REDIS_ENABLED="false"

# Redis服务器地址
REDIS_HOST="localhost"

# Redis服务器端口
# 说明：Redis默认端口是6379
REDIS_PORT="6379"

# Redis密码（如需要）
# 说明：如果Redis设置了密码，在此填写
REDIS_PASSWORD=""

# Redis数据库编号
# 说明：Redis支持多个数据库，默认为0
# 建议：不同项目使用不同编号避免冲突
REDIS_DB="0"

# ================================================================================
# 📌 配置完成检查清单
# ================================================================================
# 在启动服务前，请确认以下配置：
# [ ] 已复制此文件为 .env
# [ ] 已修改 DATABASE_URL 中的数据库密码
# [ ] 已修改 JWT_SECRET 为强随机密钥（生产环境）
# [ ] 已修改 ENCRYPTION_KEY 为强随机密钥（生产环境）
# [ ] 已配置 SMTP_* 相关参数（如需邮件功能）
# [ ] 已安装并启动 PostgreSQL 数据库
# [ ] 已初始化数据库（运行 sql_init/init_db.js）
# [ ] 已安装项目依赖（npm install）
# ================================================================================

# ================================================================================
# 🗂️ 备份配置（用于数据库管理脚本）
# ================================================================================
# 备份文件存储目录
BACKUP_DIR=./backups

# 是否压缩备份文件 (true/false)
BACKUP_COMPRESS=false
