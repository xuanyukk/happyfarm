# ================================================================================
# 开心农场 Docker 部署环境变量配置模板
# 作者：DevOps团队
# 日期：2026-06-01
# 版本：v1.4.0
# 功能描述：Docker 容器化部署所需的所有环境变量配置模板（完整版）
# 更新记录：
#   2026-05-14 - v1.2.0 - 初始版本
#   2026-06-01 - v1.4.0 - 补充数据库连接池、缓存、慢查询、Grafana、日志告警、
#                          日志采样、安全增强、JWT增强、告警通知、限流增强、
#                          监控、备份增强等约40个缺失环境变量
#
# ⚠️ 重要提示：
# 1. 此文件是模板文件，请复制为 .env 并填入实际配置值
# 2. .env 文件包含敏感信息（密码、密钥等），绝对不要提交到版本控制系统
# 3. 生产环境必须修改所有默认密码和密钥
# 4. 修改配置后需要重启 Docker 容器才能生效
# 5. 本文件供 docker-compose.yml 通过 env_file 指令加载
# ================================================================================

# ================================================================================
# 🐳 数据库容器配置
# ================================================================================
# PostgreSQL 数据库容器配置
# 这些配置会被 Docker Compose 使用来初始化 PostgreSQL 容器
POSTGRES_DB=happy_farm
POSTGRES_USER=happy_farm
POSTGRES_PASSWORD=happy_farm_password

# ================================================================================
# 🔌 数据库连接配置
# ================================================================================
# PostgreSQL 数据库连接字符串
# 格式：postgresql://用户名:密码@主机:端口/数据库名
# 说明：
#   - 用户名：Docker 容器中 PostgreSQL 的用户名
#   - 密码：数据库密码（必须修改为实际密码）
#   - postgres：Docker 服务名（在 Docker 网络中使用）
#   - 5432：PostgreSQL 默认端口
#   - happy_farm：数据库名称
DATABASE_URL=postgresql://happy_farm:happy_farm_password@postgres:5432/happy_farm

# 数据库连接单独配置（用于数据库管理脚本）
# 这些变量会被 db_manager.js 和 docsExportService.js 使用
DB_HOST=postgres
DB_PORT=5432
DB_NAME=happy_farm
DB_USER=happy_farm
DB_PASSWORD=happy_farm_password

# ================================================================================
# 🔧 数据库连接池配置
# ================================================================================
# 连接池最大连接数
# 说明：数据库连接池允许的最大并发连接数
# 建议：根据服务器CPU核心数和并发量调整，一般 20-50
DB_POOL_MAX=25

# 连接池最小连接数
# 说明：连接池保持的最小空闲连接数，减少连接建立开销
# 建议：设置为预期平均并发量的 20%-30%
DB_POOL_MIN=5

# 连接池空闲超时（毫秒）
# 说明：空闲连接超过此时间后自动释放
# 建议：生产环境 30000-60000（30-60秒）
DB_POOL_IDLE_TIMEOUT=60000

# 连接池连接超时（毫秒）
# 说明：获取新连接的最大等待时间，超时则报错
# 建议：生产环境 5000-10000（5-10秒）
DB_POOL_CONNECTION_TIMEOUT=5000

# SQL语句执行超时（毫秒）
# 说明：单条SQL语句的最大执行时间，超时则取消
# 建议：生产环境 30000-60000（30-60秒）
DB_POOL_STATEMENT_TIMEOUT=60000

# 连接最大使用次数
# 说明：单个连接使用多少次后自动销毁重建，防止连接泄漏
DB_POOL_MAX_USES=10000

# 连接最大生命周期（秒）
# 说明：单个连接的最大存活时间，超时后自动销毁重建
DB_POOL_MAX_LIFETIME=7200

# ================================================================================
# 💾 数据库查询缓存配置
# ================================================================================
# 是否启用查询缓存
# 说明：启用后自动缓存 SELECT 查询结果，提升读性能
# 可选值：true（启用）/ false（禁用）
DB_CACHE_ENABLED=true

# 缓存TTL（毫秒）
# 说明：缓存条目的默认过期时间
# 建议：根据数据更新频率调整，30000-300000（30秒-5分钟）
DB_CACHE_TTL=30000

# 缓存最大条目数
# 说明：内存中最多缓存的查询结果数量
# 建议：根据服务器内存调整，500-5000
DB_CACHE_MAX_SIZE=1000

# ================================================================================
# 🐢 慢查询监控配置
# ================================================================================
# 慢查询阈值（毫秒）
# 说明：执行时间超过此值的SQL查询将被记录为慢查询
# 建议：生产环境 1000-3000（1-3秒）
SLOW_QUERY_THRESHOLD=1000

# ================================================================================
# 🔐 JWT 认证配置
# ================================================================================
# JWT 密钥 - 用于签名和验证 JWT 令牌
# ⚠️ 生产环境必须使用强随机密钥！
# 生成方式：在终端运行以下命令生成随机密钥
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# 说明：此密钥用于保护用户登录状态，泄露会导致安全问题
JWT_SECRET=your_jwt_secret_key_here

# JWT 访问令牌过期时间
# 说明：用户登录后获得的访问令牌有效期
# 格式：支持多种格式，如：
#   - "2h" = 2小时
#   - "30m" = 30分钟
#   - "1d" = 1天
#   - "7d" = 7天
# 建议：生产环境建议设置较短时间（如15-30分钟）提高安全性
JWT_EXPIRES_IN=7d

# JWT 刷新令牌过期时间
# 说明：用于刷新访问令牌的刷新令牌有效期
# 建议：设置较长时间，让用户无需频繁登录
JWT_REFRESH_EXPIRES_IN=30d

# ================================================================================
# 🔐 JWT 增强配置（tokenService.js 使用）
# ================================================================================
# JWT 访问令牌专用密钥
# 说明：如果未设置，则回退使用 JWT_SECRET
# 建议：生产环境设置独立的访问令牌密钥提高安全性
JWT_ACCESS_SECRET=

# JWT 刷新令牌专用密钥
# 说明：如果未设置，则回退使用 JWT_SECRET
# 建议：生产环境设置独立的刷新令牌密钥提高安全性
JWT_REFRESH_SECRET=

# JWT 访问令牌过期时间（tokenService.js 专用）
# 说明：优先级高于 JWT_EXPIRES_IN
# 建议：15m-1h
JWT_ACCESS_EXPIRES=15m

# JWT 刷新令牌过期时间（tokenService.js 专用）
# 说明：优先级高于 JWT_REFRESH_EXPIRES_IN
# 建议：7d-30d
JWT_REFRESH_EXPIRES=7d

# ================================================================================
# 🖥️ 服务器配置
# ================================================================================
# 服务监听端口
# 说明：后端 HTTP 服务监听的端口号
# 注意：如果端口被占用，需要修改此值或关闭占用端口的程序
PORT=3000

# 服务监听主机
# 说明：
#   - "localhost"：仅本地可访问（开发环境推荐）
#   - "0.0.0.0"：允许所有 IP 访问（Docker 环境必须）
HOST=0.0.0.0

# Node.js 运行环境
# 说明：
#   - "development"：开发环境，启用调试日志、热重载等
#   - "production"：生产环境，启用性能优化、禁用调试
NODE_ENV=production

# ================================================================================
# 📝 日志配置
# ================================================================================
# 日志输出级别
# 说明：控制日志输出的详细程度，从低到高依次为：
#   - "error"：仅输出错误
#   - "warn"：输出警告和错误
#   - "info"：输出一般信息、警告和错误
#   - "debug"：输出所有信息（开发调试用）
LOG_LEVEL=info

# 日志文件路径（用于数据库管理脚本）
LOG_FILE=./logs/app.log

# ================================================================================
# 🔔 日志告警配置（高级日志功能）
# ================================================================================
# 是否启用日志告警
# 说明：启用后，特定级别的日志会触发告警通知
# 可选值：true（启用）/ false（禁用）
ENABLE_LOG_ALERTS=true

# 告警通知渠道
# 说明：启用的告警渠道列表，多个用逗号分隔
# 可选渠道：email, webhook, sms
# 示例："email,webhook"
LOG_ALERT_CHANNELS=email

# 是否启用邮件告警
# 说明：通过邮件发送告警通知
# 可选值：true / false
LOG_ALERT_EMAIL_ENABLED=false

# 邮件告警发件人
LOG_ALERT_EMAIL_FROM=alerts@farmgame.com

# 邮件告警收件人
LOG_ALERT_EMAIL_TO=admin@farmgame.com

# SMTP 是否启用SSL加密
# 可选值：true / false
SMTP_SECURE=false

# 是否启用Webhook告警
# 可选值：true / false
LOG_ALERT_WEBHOOK_ENABLED=false

# Webhook告警URL
LOG_ALERT_WEBHOOK_URL=

# ================================================================================
# 📊 日志采样配置（高级日志功能）
# ================================================================================
# 默认日志采样率
# 说明：全局默认采样率，1.0=100%记录，0.5=50%记录
# 取值范围：0.0 - 1.0
LOG_DEFAULT_SAMPLE_RATE=1.0

# 访问日志采样率
# 说明：HTTP请求日志的采样率
# 取值范围：0.0 - 1.0
LOG_ACCESS_SAMPLE_RATE=0.5

# 性能日志采样率
# 说明：性能相关日志的采样率
# 取值范围：0.0 - 1.0
LOG_PERF_SAMPLE_RATE=0.5

# ================================================================================
# 🛡️ 安全配置
# ================================================================================
# CORS 允许的源地址
# 说明：允许哪些前端域名访问后端 API（跨域资源共享）
# 格式：多个地址用逗号分隔
# 示例：
#   本地开发："http://localhost:5173,http://localhost:5174"
#   生产环境："https://farm.example.com,https://admin.farm.example.com"
CORS_ORIGIN=http://localhost,http://localhost:5173,http://localhost:5174

# 是否启用安全确认 (true/false)
# 说明：设置为 false 可跳过确认提示（生产环境不建议）
SAFETY_CONFIRM=true

# ================================================================================
# 🛡️ 安全增强配置
# ================================================================================
# 是否启用双因素认证
# 说明：启用后用户登录需要二次验证
# 可选值：true（启用）/ false（禁用）
TWO_FACTOR_ENABLED=false

# 是否启用CSRF防护
# 说明：启用后API请求需要CSRF令牌验证
# 可选值：true（启用）/ false（禁用）
CSRF_ENABLED=false

# ================================================================================
# 🚦 速率限制配置
# ================================================================================
# 速率限制时间窗口
# 说明：在多长时间内统计请求次数，防止恶意攻击
# 格式：
#   - "15m" = 15分钟
#   - "1h" = 1小时
#   - "1d" = 1天
RATE_LIMIT_WINDOW=15m

# 速率限制最大请求数（登录接口全局限制）
# 说明：在时间窗口内允许的最大请求数，超过会被拒绝
# 建议：
#   - 开发环境：100-1000（方便测试）
#   - 生产环境：10-100（防止恶意攻击）
RATE_LIMIT_MAX=100

# ================================================================================
# 🚦 速率限制增强配置（分级限流）
# ================================================================================
# IP级别：时间窗口内允许的最大请求次数
# 说明：基于IP地址的限流，防止单IP恶意刷接口
RATE_LIMIT_IP_POINTS=60

# IP级别：时间窗口（秒）
# 说明：IP限流的统计时间窗口
RATE_LIMIT_IP_DURATION=60

# IP级别：超限后封禁时间（秒）
# 说明：IP超过限制后被封禁的时长
RATE_LIMIT_IP_BLOCK=60

# 用户级别：时间窗口内允许的最大请求次数
# 说明：基于用户身份的限流，认证用户可获取更高配额
RATE_LIMIT_USER_POINTS=120

# 用户级别：时间窗口（秒）
# 说明：用户限流的统计时间窗口
RATE_LIMIT_USER_DURATION=60

# 用户级别：超限后封禁时间（秒）
# 说明：用户超过限制后被封禁的时长
RATE_LIMIT_USER_BLOCK=300

# ================================================================================
# 📧 邮件服务配置（SMTP协议）
# ================================================================================
# SMTP 服务器地址
# 说明：用于发送邮件的 SMTP 服务器地址
# 常见服务商：
#   - Gmail：smtp.gmail.com
#   - QQ邮箱：smtp.qq.com
#   - 163邮箱：smtp.163.com
#   - 企业邮箱：请咨询服务商
SMTP_HOST=smtp.example.com

# SMTP 服务器端口
# 说明：
#   - 587：TLS加密端口（推荐）
#   - 465：SSL加密端口
#   - 25：非加密端口（不推荐）
SMTP_PORT=587

# SMTP 用户名
# 说明：登录 SMTP 服务器的用户名（通常是邮箱地址）
SMTP_USER=your-email@example.com

# SMTP 密码
# 说明：登录 SMTP 服务器的密码或授权码
# 注意：部分邮箱服务商需要使用授权码而非登录密码
SMTP_PASS=your-email-password

# 发件人邮箱地址
# 说明：显示在邮件发件人位置的邮箱地址
SMTP_FROM=no-reply@example.com

# 是否启用邮件服务
# 说明：
#   - "true"：启用邮件发送功能
#   - "false"：禁用邮件功能（密码重置等功能不可用）
SMTP_ENABLED=false

# 密码重置令牌有效期（分钟）
# 说明：用户请求密码重置后，链接的有效时间
PASSWORD_RESET_TOKEN_EXPIRES=30

# ================================================================================
# 📧 邮件服务配置（EMAIL_ 别名 - config/index.js 使用）
# 说明：以下变量与SMTP_*变量保持相同值，确保不同模块兼容
# ================================================================================
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=your-email@example.com
EMAIL_PASS=your-email-password
EMAIL_FROM=no-reply@example.com

# ================================================================================
# 🔑 数据加密配置
# ================================================================================
# 敏感数据加密密钥
# ⚠️ 生产环境必须使用强随机密钥！
# 生成方式：在终端运行以下命令生成随机密钥
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# 说明：用于加密数据库中存储的敏感数据
ENCRYPTION_KEY=your_strong_encryption_key_here

# ================================================================================
# 🚀 Redis 缓存配置
# ================================================================================
# 是否启用 Redis
# 说明：
#   - "true"：启用 Redis 缓存和队列功能
#   - "false"：禁用 Redis，使用内存缓存（不推荐生产环境）
REDIS_ENABLED=true

# Redis 服务器地址
REDIS_HOST=redis

# Redis 服务器端口
# 说明：Redis 默认端口是 6379
REDIS_PORT=6379

# Redis 密码（如需要）
# 说明：如果 Redis 设置了密码，在此填写
REDIS_PASSWORD=

# Redis 数据库编号
# 说明：Redis 支持多个数据库，默认为 0
# 建议：不同项目使用不同编号避免冲突
REDIS_DB=0

# Redis 完整连接URL
# 说明：Redis连接字符串，格式 redis://[:密码@]主机:端口/数据库编号
# 如果设置了此变量，将优先使用（config/index.js 使用）
# 示例：redis://:password@redis:6379/0
REDIS_URL=

# ================================================================================
# 🗂️ 备份配置
# ================================================================================
# 备份文件存储目录
BACKUP_DIR=./backups

# 是否压缩备份文件 (true/false)
BACKUP_COMPRESS=false

# ================================================================================
# 🗂️ 备份增强配置（config/index.js 使用）
# ================================================================================
# 是否启用自动备份
# 说明：启用后定时自动执行数据库备份
# 可选值：true（启用）/ false（禁用）
BACKUP_ENABLED=false

# 自动备份时间表达式（cron格式）
# 说明：每天凌晨2点执行备份
# 格式：分 时 日 月 周
# 示例："0 2 * * *" = 每天凌晨2:00
BACKUP_INTERVAL=0 2 * * *

# 备份文件存储目录（增强版）
# 说明：与 BACKUP_DIR 保持一致的完整路径
BACKUP_DIRECTORY=./backups

# ================================================================================
# 📈 系统监控配置
# ================================================================================
# 是否启用系统监控
# 说明：启用后定期采集服务器资源、数据库性能、应用健康状态
# 可选值：true（启用）/ false（禁用）
MONITORING_ENABLED=true

# 监控采集间隔（毫秒）
# 说明：监控数据采集的时间间隔
# 建议：60000（1分钟）- 300000（5分钟）
MONITORING_INTERVAL=60000

# ================================================================================
# 📊 Grafana 监控面板配置
# ================================================================================
# Grafana 管理员用户名
# 说明：Grafana 监控面板的管理员用户名
GF_SECURITY_ADMIN_USER=admin

# Grafana 管理员密码
# 说明：Grafana 监控面板的管理员密码
# ⚠️ 生产环境必须修改为强密码！
GF_SECURITY_ADMIN_PASSWORD=your_grafana_password

# Grafana 服务地址
# 说明：Grafana 监控面板的访问地址，前端嵌入仪表板时使用
# Docker部署中，Grafana运行在独立容器，后端通过此地址代理请求
# 格式：http://主机:端口
# 示例：
#   Docker部署："http://grafana:3000"
#   本地开发："http://localhost:3001"
GRAFANA_URL=http://grafana:3000

# ================================================================================
# 🗄️ pgAdmin 4 数据库管理工具配置
# ================================================================================
# pgAdmin 默认登录邮箱
# 说明：pgAdmin 4 Web 界面的登录账号
PGADMIN_DEFAULT_EMAIL=admin@happyfarm.com

# pgAdmin 默认登录密码
# 说明：pgAdmin 4 Web 界面的登录密码
# ⚠️ 生产环境建议修改为强密码
PGADMIN_DEFAULT_PASSWORD=happyfarm123

# ================================================================================
# 📢 第三方告警通知配置
# ================================================================================
# 企业微信通知配置
# 说明：通过企业微信机器人发送告警通知
# Webhook地址（从企业微信群机器人获取）
WECHAT_WEBHOOK_URL=
# Webhook密钥
WECHAT_SECRET=

# 钉钉通知配置
# 说明：通过钉钉机器人发送告警通知
# Webhook地址（从钉钉群机器人获取）
DINGTALK_WEBHOOK_URL=
# 钉钉签名密钥
DINGTALK_SECRET=

# 短信通知配置
# 说明：通过短信网关发送紧急告警
# 短信API接口地址
SMS_API_URL=
# 短信API密钥
SMS_API_KEY=
# 短信模板ID
SMS_TEMPLATE_ID=

# ================================================================================
# 📌 配置完成检查清单
# ================================================================================
# 在启动服务前，请确认以下配置：
# [ ] 已复制此文件为 .env
# [ ] 已修改 DATABASE_URL 中的数据库密码
# [ ] 已修改 JWT_SECRET 为强随机密钥（生产环境）
# [ ] 已修改 ENCRYPTION_KEY 为强随机密钥（生产环境）
# [ ] 已配置 SMTP_* / EMAIL_* 相关参数（如需邮件功能）
# [ ] 已配置 GRAFANA_URL 指向正确的Grafana地址
# [ ] 已根据服务器配置调整 DB_POOL_* 参数
# [ ] 已配置告警通知渠道（企业微信/钉钉/短信）
# [ ] 已确保 Docker 环境已正确设置
# [ ] 已运行 docker-compose up -d 启动服务
# ================================================================================
