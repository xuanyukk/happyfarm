# ================================================================================
# 开心农场前端环境变量配置模板
# 作者：开发者
# 日期：2026-05-15
# 版本：v1.2.0
# 功能描述：前端应用运行所需的所有环境变量配置模板
# 
# ⚠️ 重要提示：
# 1. Vite环境变量必须以 VITE_ 开头才能在前端代码中访问
# 2. 此文件是模板文件，请复制为 .env 并填入实际配置值
# 3. .env 文件不应提交到版本控制系统
# 4. 修改配置后需要重启开发服务器才能生效
# ================================================================================

# ================================================================================
# 🌐 API接口地址配置
# ================================================================================
# 后端服务的完整API地址
# 说明：前端通过此地址与后端进行通信
# 格式：http://主机:端口/api 或 https://域名/api
# 
# 配置示例：
#   本地开发：VITE_API_URL=http://localhost:3001/api
#   生产环境：VITE_API_URL=https://api.farm.example.com/api
#   同域名部署：VITE_API_URL=/api（如果前后端部署在同一域名）
VITE_API_URL=http://localhost:3001/api

# ================================================================================
# 📝 日志级别配置
# ================================================================================
# 前端日志输出级别
# 说明：控制浏览器控制台中日志输出的详细程度
# 可选值（从少到多）：
#   - "error"：仅输出错误信息
#   - "warn"：输出警告和错误
#   - "info"：输出一般信息、警告和错误
#   - "debug"：输出所有调试信息（开发调试推荐）
# 
# 建议：
#   - 开发环境："debug"（方便调试）
#   - 生产环境："error"或"warn"（减少控制台输出）
VITE_LOG_LEVEL=debug

# ================================================================================
# 🚀 日志上报配置
# ================================================================================
# 启用远程日志上报
# 说明：控制是否将前端日志上报到后端服务器
# 可选值：true（启用）、false（禁用）
# 
# 建议：
#   - 开发环境：false（方便本地调试）
#   - 生产环境：true（收集错误日志）
VITE_ENABLE_LOG_REPORT=false

# 日志上报接口地址
# 说明：单条日志上报的API端点
VITE_LOG_REPORT_ENDPOINT=/api/client-logs

# 批量日志上报接口地址
# 说明：多条日志批量上报的API端点
VITE_LOG_BATCH_REPORT_ENDPOINT=/api/client-logs/batch

# 日志上报间隔（毫秒）
# 说明：定时批量上报日志的时间间隔
VITE_LOG_REPORT_INTERVAL=30000

# 启用控制台输出
# 说明：控制是否在浏览器控制台输出日志
VITE_ENABLE_LOG_CONSOLE=true

# ================================================================================
# 📌 配置完成检查清单
# ================================================================================
# 在启动服务前，请确认以下配置：
# [ ] 已复制此文件为 .env
# [ ] 已确认 VITE_API_URL 指向正确的后端地址
# [ ] 后端服务已启动并在对应端口监听
# [ ] 已安装项目依赖（npm install）
# [ ] 如需HTTPS，可在 vite.config.js 中配置
# [ ] 生产环境建议启用 VITE_ENABLE_LOG_REPORT=true
# ================================================================================
