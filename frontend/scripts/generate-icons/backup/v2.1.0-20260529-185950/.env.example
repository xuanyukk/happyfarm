# ================================================================================
# 开心农场 AI 图标生成工具 - 环境变量配置模板
# 文件名: .env.example
# 作者: 开发者
# 日期: 2026-05-29
# 版本: v2.0.0
# 功能描述: 配置硅基流动(SiliconFlow) API 密钥和所有生成工具的参数
# 使用说明:
#   1. 将此文件复制为 .env: copy .env.example .env
#   2. 填入你的 SILICONFLOW_API_KEY
#   3. 根据需要调整其他参数（可选，默认值已优化）
# 注意: .env 文件已被 .gitignore 忽略，不会提交到 Git
# ================================================================================

# ================================================================================
# 快速开始指南
# ================================================================================
# 1. 访问 https://cloud.siliconflow.cn/account/ak 获取 API Key
# 2. 将下面的 SILICONFLOW_API_KEY=your-api-key-here 替换为你的实际密钥
# 3. 运行: cd frontend/scripts/generate-icons; node kolors-generate-crops.cjs (免费基础作物)
#    或: cd frontend/scripts/generate-icons; node flux-generate-effects.cjs (特效作物)
#    或: cd frontend/scripts/generate-icons; node generateIcons.cjs (UI图标)
# ================================================================================

# ================================================================================
# 硅基流动(SiliconFlow) API 密钥（必填！）
# ================================================================================
# 获取地址: https://cloud.siliconflow.cn/account/ak
# 注册步骤:
#   1. 访问上述地址
#   2. 注册/登录硅基流动账号
#   3. 点击"创建 API Key"
#   4. 复制生成的密钥（格式类似: sk-xxxxx...）
# 注意:
#   - 此密钥是访问所有 AI 模型的凭证，请妥善保管
#   - 不要将 .env 文件提交到 Git（已配置 .gitignore）
#   - 如果密钥泄露，请立即在控制台删除并重新生成
# ================================================================================
SILICONFLOW_API_KEY=your-api-key-here

# ================================================================================
# Qwen/Qwen-Image 模型配置（UI图标生成工具 & 基础作物生成工具）
# ================================================================================
# 用途: 生成种子图标、道具图标、土地图标、UI按钮/面板、基础/经济作物生长图和成品
# 工具: generateIcons.cjs, kolors-generate-crops.cjs
# 文档: https://cloud.siliconflow.cn/models/Qwen/Qwen-Image
# 推荐场景: 2D 游戏 UI 元素和作物图标，风格统一，原生支持游戏像素风格
# 注意: Qwen/Qwen-Image 要求图片最小尺寸 256x256，128x128会报错
#
# 配置说明:
#   API_BASE_URL: 硅基流动 API 地址（通常不需要修改）
#   IMAGE_MODEL: 使用的 AI 模型
#   IMAGE_SIZE: 生成图片尺寸（UI工具用，最小128x128）
#   NUM_INFERENCE_STEPS: 推理步数，越高质量越好但越慢 (建议 20-40)
#   GUIDANCE_SCALE: 提示词引导强度，越高越严格遵循提示词 (建议 5-10)
# ================================================================================
API_BASE_URL=https://api.siliconflow.cn/v1
IMAGE_MODEL=Qwen/Qwen-Image
IMAGE_SIZE=128x128
NUM_INFERENCE_STEPS=30
GUIDANCE_SCALE=7.5

# ================================================================================
# FLUX.1-Kontext-dev 模型配置（特效作物生成工具）
# ================================================================================
# 用途: 生成稀有/顶级作物的生长阶段图和成品图标
# 工具: flux-generate-effects.cjs
# 文档: https://cloud.siliconflow.cn/models/black-forest-labs/FLUX.1-Kontext-dev
# 特点:
#   - 擅长高质量游戏美术风格
#   - 能准确还原发光、光晕、粒子、旋转光环等特效
#   - 付费使用（约 0.015 元/张）
#   - 推荐用于需要特效的稀有/顶级作物 (ID 35-84)
#
# 配置说明:
#   FLUX_MODEL: 使用的 FLUX 模型
#   FLUX_NUM_INFERENCE_STEPS: 推理步数，建议 25-40
#   FLUX_GUIDANCE_SCALE: 引导强度，建议 6-10
# ================================================================================
FLUX_MODEL=black-forest-labs/FLUX.1-Kontext-dev
FLUX_NUM_INFERENCE_STEPS=35
FLUX_GUIDANCE_SCALE=8.0

# ================================================================================
# Kwai-Kolors/Kolors 模型配置（基础作物生长阶段生成工具）
# ================================================================================
# ⚠️ 重要变更(v1.2): 因Kwai-Kolors/Kolors不支持游戏像素风格，已切换至Qwen/Qwen-Image。
#   KOLORS_MODEL 默认值已改为 Qwen/Qwen-Image，尺寸需≥256x256。
#   如需回退使用Kolors模型，请将 KOLORS_MODEL 显式设为 Kwai-Kolors/Kolors
#   并将 KOLORS_IMAGE_SIZE 设为 128x128。
#
# 用途: 生成基础/经济作物的五阶段生长图和成品图标
# 工具: kolors-generate-crops.cjs
# 模型: 默认 Qwen/Qwen-Image（原生支持游戏像素图标）
# 特点:
#   - Qwen/Qwen-Image 原生支持游戏像素图标和透明背景
#   - 需最小尺寸 256x256（由 KOLORS_IMAGE_SIZE 控制）
#   - 付费使用
#
# 配置说明:
#   KOLORS_MODEL: 使用的模型(Qwen或Kolors)
#   KOLORS_IMAGE_SIZE: 基础作物生成尺寸（最小256x256）
#   KOLORS_NUM_INFERENCE_STEPS: 推理步数，建议 20-40
#   KOLORS_GUIDANCE_SCALE: 引导强度，建议 5-12
# ================================================================================
KOLORS_MODEL=Qwen/Qwen-Image
KOLORS_IMAGE_SIZE=256x256
KOLORS_NUM_INFERENCE_STEPS=30
KOLORS_GUIDANCE_SCALE=10

# ================================================================================
# 通用输出配置
# ================================================================================
# 用途: 控制生成的图片保存位置
# 配置说明:
#   OUTPUT_DIR: 输出目录（相对于项目根目录）
#     默认: frontend/public/assets
#     子目录:
#       - crops/stages/  (作物生长阶段图)
#       - icons/crops/   (作物成品图标)
#       - icons/seeds/   (种子图标)
#       - icons/items/   (道具图标)
#       - icons/land/    (土地图标)
#       - ui/            (UI元素)
# ================================================================================
OUTPUT_DIR=frontend/public/assets

# ================================================================================
# 并发与速率限制配置（重要！）
# ================================================================================
# 用途: 避免触发 API 限流，提高生成成功率
# 建议:
#   - 如果网络较慢或遇到限流错误，请降低并发数、增加延迟
#   - 首次使用建议先用较小的值测试
#
# 配置说明:
#   MAX_CONCURRENT: UI 工具的最大并发请求数
#   REQUEST_DELAY_MS: UI 工具每次请求之间的延迟（毫秒）
#   FLUX_MAX_CONCURRENT: FLUX 工具的最大并发数（FLUX 推理较慢，建议更低）
#   FLUX_REQUEST_DELAY_MS: FLUX 工具的请求延迟
#   KOLORS_MAX_CONCURRENT: Kolors 工具的最大并发数（可适当提高）
#   KOLORS_REQUEST_DELAY_MS: Kolors 工具的请求延迟
# ================================================================================

# UI 图标工具并发控制
MAX_CONCURRENT=3
REQUEST_DELAY_MS=2000

# FLUX 特效工具并发控制
FLUX_MAX_CONCURRENT=2
FLUX_REQUEST_DELAY_MS=3000

# Kolors 基础工具并发控制
KOLORS_MAX_CONCURRENT=3
KOLORS_REQUEST_DELAY_MS=1500

# ================================================================================
# 常见问题 (FAQ)
# ================================================================================
#
# Q: 为什么有三个不同的工具？
# A: 三个工具分工明确:
#    - kolors-generate-crops.cjs: 基础/经济作物1-34（Qwen模型，256x256）
#    - flux-generate-effects.cjs: 稀有/顶级作物35-84（FLUX特效，128x128）
#    - generateIcons.cjs: 种子/道具/土地/UI元素（Qwen模型，128x128）
#
# Q: Kolors工具现在用什么模型？
# A: v1.2起默认用Qwen/Qwen-Image（游戏图标专用），如需用Kolors请设
#    KOLORS_MODEL=Kwai-Kolors/Kolors 和 KOLORS_IMAGE_SIZE=128x128
#
# Q: 如何测试配置是否正确？
# A: 使用 --dry-run 参数预览，例如:
#    node kolors-generate-crops.cjs --dry-run
#
# Q: 遇到 API 限流错误怎么办？
# A: 降低 MAX_CONCURRENT，增加 REQUEST_DELAY_MS
#
# Q: 生成的图片质量不满意怎么办？
# A: 可以尝试:
#    - 增加 NUM_INFERENCE_STEPS (例如 30→40)
#    - 调整 GUIDANCE_SCALE (例如 7.5→8.5)
#    - 查看 README.md 中的提示词文档
#
# Q: 在哪里可以找到更多帮助？
# A: 查看 frontend/scripts/generate-icons/README.md
# ================================================================================
