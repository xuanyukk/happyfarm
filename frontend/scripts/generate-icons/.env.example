# ================================================================================
# 开心农场 AI 图标生成工具 - 环境变量配置模板
# 文件名: .env.example
# 作者: 开发者
# 日期: 2026-05-29
# 版本: v3.0.0
# 功能描述: 配置火山引擎方舟(Ark) API 密钥和所有生成工具的参数
# 使用说明:
#   1. 将此文件复制为 .env: copy .env.example .env
#   2. 填入你的 ARK_API_KEY
#   3. 根据需要调整其他参数（可选，默认值已优化）
# 注意: .env 文件已被 .gitignore 忽略，不会提交到 Git
# ================================================================================

# ================================================================================
# 快速开始指南
# ================================================================================
# 1. 访问 https://console.volcengine.com/ark/region:ark+cn-beijing/apiKey 获取 API Key
# 2. 将下面的 ARK_API_KEY=your-api-key-here 替换为你的实际密钥
# 3. 运行: cd frontend/scripts/generate-icons; node kolors-generate-crops.cjs (基础/经济作物)
#    或: cd frontend/scripts/generate-icons; node flux-generate-effects.cjs (稀有/顶级作物)
#    或: cd frontend/scripts/generate-icons; node generateIcons.cjs (UI图标)
# ================================================================================

# ================================================================================
# 火山引擎方舟(Ark) API 密钥（必填！）
# ================================================================================
# 获取地址: https://console.volcengine.com/ark/region:ark+cn-beijing/apiKey
# 注意:
#   - 此密钥是访问所有模型的凭证，请妥善保管
#   - 不要将 .env 文件提交到 Git（已配置 .gitignore）
#   - 如果密钥泄露，请立即在控制台删除并重新生成
# ================================================================================
ARK_API_KEY=your-api-key-here

# ================================================================================
# 火山引擎方舟 API 基础配置
# ================================================================================
ARK_API_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# ================================================================================
# Seedream 模型配置（作物生长阶段图 & 成品图标）
# ================================================================================
# 用途: 生成基础/经济/稀有/顶级作物的五阶段生长图和成品图标
# 工具: kolors-generate-crops.cjs, flux-generate-effects.cjs
# 文档: https://www.volcengine.com/docs/82379/1541523
#
# 推荐模型:
#   doubao-seedream-4.5 (最新，高质量)
#   doubao-seedream-5.0-lite (轻量版，速度快)
#
# 配置说明:
#   ARK_CROP_MODEL: 作物生成使用的模型
#   ARK_UI_MODEL: UI图标生成使用的模型
#   ARK_CROP_MAX_CONCURRENT: 作物生成最大并发数
#   ARK_CROP_REQUEST_DELAY_MS: 作物生成请求间隔(毫秒)
#   ARK_UI_MAX_CONCURRENT: UI生成最大并发数
#   ARK_UI_REQUEST_DELAY_MS: UI生成请求间隔(毫秒)
# ================================================================================
ARK_CROP_MODEL=doubao-seedream-4-5-251128
ARK_UI_MODEL=doubao-seedream-4-5-251128
ARK_CROP_MAX_CONCURRENT=2
ARK_CROP_REQUEST_DELAY_MS=3000
ARK_UI_MAX_CONCURRENT=2
ARK_UI_REQUEST_DELAY_MS=3000

# ================================================================================
# 通用输出配置
# ================================================================================
OUTPUT_DIR=frontend/public/assets

# ================================================================================
# 常见问题 (FAQ)
# ================================================================================
#
# Q: 如何获取 API Key？
# A: 访问 https://console.volcengine.com/ark/region:ark+cn-beijing/apiKey
#
# Q: 如何开通模型？
# A: 访问方舟控制台 → 模型广场 → 搜索模型名 → 点击"开通"
#
# Q: 遇到 API 限流错误怎么办？
# A: 降低 MAX_CONCURRENT，增加 REQUEST_DELAY_MS
#
# Q: 在哪里可以找到更多帮助？
# A: 查看 frontend/scripts/generate-icons/README.md
# ================================================================================