# ================================================================================
# 开心农场项目 .gitignore 配置
# 作者：开发者
# 日期：2026-06-02
# 版本：1.4.0
# 功能描述：指定不需要提交到版本控制系统的文件和目录
# 更新记录：
#   2026-06-04 - v1.3.0 - 移除不存在的旧文件和目录
#   2026-06-04 - v1.4.0 - 重新添加实际存在的需要忽略的文件夹和文件
# ================================================================================

# ================================================================================
# 一、依赖 / 编译生成目录
# ================================================================================
node_modules/
backend/node_modules/
frontend/node_modules/
__pycache__/
*/__pycache__/
*.pyc
*.pyo
*.pyd

# ================================================================================
# 二、日志 / 临时文件
# ================================================================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log.*

# ================================================================================
# 三、IDE / 编辑器配置
# ================================================================================
.vscode/
.idea/
.vim/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ================================================================================
# 四、环境配置 / 敏感文件
# ================================================================================
.env
.env.local
.env.*.local
*.env
backend/.env
frontend/.env
sql_init/.env
.env.docker
.deploy_checkpoint.json
.deploy_backup/
*.progress.json
*.model-usage.json
.kolors-progress.json
.flux-progress.json
conversion_report.txt

# ================================================================================
# 五、构建产物 / 静态资源
# ================================================================================
dist/
backend/dist/
frontend/dist/
frontend/coverage/
backend/coverage/
docs-website/.vitepress/cache/
docs-website/.vitepress/dist/
.build/
.cache/
图片/
图片_converted/

# ================================================================================
# 六、归档文档（已归档到 docs/archive）
# ================================================================================
docs/archive/

# ================================================================================
# 七、Trae 规则文件
# ================================================================================
.trae/

# ================================================================================
# 八、Husky
# ================================================================================
.husky/_/

# ================================================================================
# 九、Docker
# ================================================================================
docker-compose.override.yml

# ================================================================================
# 十、其他
# ================================================================================
*.pid
*.seed
*.pid.lock
*.tmp
*.temp
*.bak
*.cache
